{
  "name": "binary-coffee-cli",
  "version": "2.0.0",
  "description": "Terminal UI client for Binary Coffee blog - browse posts, manage content, and interact with the community",
  "main": "./dist/index.js",
  "bin": {
    "bncf": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stescobedo92/binary-coffee-cli.git"
  },
  "keywords": [
    "binary-coffee",
    "cli",
    "tui",
    "blog",
    "terminal"
  ],
  "author": "stescobedo92",
  "type": "module",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/stescobedo92/binary-coffee-cli/issues"
  },
  "homepage": "https://github.com/stescobedo92/binary-coffee-cli#readme",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "figlet": "^1.8.0",
    "graphql": "^16.10.0",
    "graphql-request": "^7.1.2",
    "ink": "^5.1.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "open": "^10.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
